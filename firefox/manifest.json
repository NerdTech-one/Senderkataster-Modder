{
  "manifest_version": 3,
  "name": "Senderkataster Modder by NerdTech",
  "version": "1.2.2",
  "description": "Erweiterung um die Nutzererfahrung der Webseite senderkataster.at zu verbessern.",
  "content_scripts": [
    {
      "matches": ["*://*.senderkataster.at/*"],
      "js": ["content.js"],
      "world": "MAIN", 
      "run_at": "document_start"
    }
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "senderkataster-modder@nerdtech.one",
      "strict_min_version": "142.0",
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  }
}