{
  "manifest_version": 3,
  "name": "Senderkataster Modder by NerdTech",
  "version": "1.2",
  "permissions": [
    "scripting"
  ],
  "host_permissions": [
    "*://*.senderkataster.at/*"
  ],
  "description": "Erweiterung um die Nutzererfahrung der Webseite senderkataster.at zu verbessern.",
  "content_scripts": [
    {
      "matches": ["https://www.senderkataster.at/*"],
      "js": ["content.js"],
      "world": "MAIN", 
      "run_at": "document_start"
    }
  ]
}